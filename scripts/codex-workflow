#!/usr/bin/env bash
set -euo pipefail

ROOT="/Users/rimpeihata/Desktop/auto-annotation-research"
WORKFLOW_DIR="$ROOT/.agents/workflows"

usage() {
  cat <<'EOF'
Usage:
  ./scripts/codex-workflow list
  ./scripts/codex-workflow show <workflow-name>
  ./scripts/codex-workflow path <workflow-name>

Examples:
  ./scripts/codex-workflow list
  ./scripts/codex-workflow show sync-annotation-report
  ./scripts/codex-workflow path implement-next-improvement
EOF
}

require_workflow() {
  local name="$1"
  local path="$WORKFLOW_DIR/$name.md"
  if [[ ! -f "$path" ]]; then
    echo "Workflow not found: $name" >&2
    exit 1
  fi
  printf '%s\n' "$path"
}

cmd="${1:-list}"

case "$cmd" in
  list)
    find "$WORKFLOW_DIR" -maxdepth 1 -type f -name '*.md' \
      ! -name 'README.md' ! -name '_conventions.md' \
      -exec basename {} .md \; | sort
    ;;
  show)
    [[ $# -ge 2 ]] || { usage; exit 1; }
    workflow_path="$(require_workflow "$2")"
    cat "$workflow_path"
    ;;
  path)
    [[ $# -ge 2 ]] || { usage; exit 1; }
    require_workflow "$2"
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    usage
    exit 1
    ;;
esac
